{
  "name": "@ahmedrowaihi/better-upload-server",
  "description": "The Better Upload server library. Simple and easy file uploads for React.",
  "version": "3.0.17",
  "type": "module",
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "tsc",
    "test": "vitest"
  },
  "files": [
    "dist"
  ],
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    },
    "./clients": {
      "import": "./dist/clients/index.mjs",
      "types": "./dist/clients/index.d.mts"
    },
    "./helpers": {
      "import": "./dist/helpers/index.mjs",
      "types": "./dist/helpers/index.d.mts"
    },
    "./adapters/next": {
      "import": "./dist/adapters/next.mjs",
      "types": "./dist/adapters/next.d.mts"
    },
    "./adapters/node": {
      "import": "./dist/adapters/node.mjs",
      "types": "./dist/adapters/node.d.mts"
    },
    "./internal": {
      "import": "./dist/internal-export.mjs",
      "types": "./dist/internal-export.d.mts"
    }
  },
  "dependencies": {
    "aws4fetch": "^1.0.20",
    "fast-xml-parser": "^5.5.9",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@repo/tsconfig": "workspace:*",
    "@types/node": "^24",
    "tsdown": "^0.21.6",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  },
  "keywords": [
    "react",
    "nextjs",
    "tanstack",
    "upload",
    "files",
    "multipart"
  ],
  "license": "MIT",
  "homepage": "https://better-upload.com",
  "bugs": {
    "url": "https://github.com/Nic13Gamer/better-upload/issues"
  },
  "author": "Nicholas",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Nic13Gamer/better-upload.git"
  }
}
