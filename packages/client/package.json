{
  "name": "@ahmedrowaihi/better-upload-client",
  "description": "The Better Upload client library. Simple and easy file uploads for React.",
  "version": "3.0.17",
  "type": "module",
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "tsc"
  },
  "files": [
    "dist"
  ],
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    },
    "./helpers": {
      "import": "./dist/helpers/index.mjs",
      "types": "./dist/helpers/index.d.mts"
    },
    "./internal": {
      "import": "./dist/internal-export.mjs",
      "types": "./dist/internal-export.d.mts"
    }
  },
  "peerDependencies": {
    "react": "*"
  },
  "devDependencies": {
    "@repo/tsconfig": "workspace:*",
    "@types/react": "^19.2.7",
    "react": "^19.2.3",
    "tsdown": "^0.21.6",
    "typescript": "^5.9.3"
  },
  "keywords": [
    "react",
    "nextjs",
    "tanstack",
    "upload",
    "files",
    "multipart"
  ],
  "license": "MIT",
  "homepage": "https://better-upload.com",
  "bugs": {
    "url": "https://github.com/Nic13Gamer/better-upload/issues"
  },
  "author": "Nicholas",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Nic13Gamer/better-upload.git"
  }
}
